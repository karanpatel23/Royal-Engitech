# Public site URL used for sitemap/Open Graph metadata
NEXT_PUBLIC_SITE_URL=https://www.royalengitech.com

# SMTP email notifications for contact/inquiry leads
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me
CONTACT_TO_EMAIL=sales@royalengitech.com
CONTACT_FROM_EMAIL=website@royalengitech.com

# Optional: enable when you add persistence with Prisma/PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/royal_engitech
SAVE_LEADS_TO_DATABASE=false

# Optional lightweight rate-limit/spam tuning placeholder for production middleware
CONTACT_RATE_LIMIT_WINDOW_SECONDS=60
CONTACT_RATE_LIMIT_MAX=5
