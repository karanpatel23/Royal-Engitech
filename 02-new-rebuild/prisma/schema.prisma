generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LeadInquiry {
  id          String   @id @default(cuid())
  name        String
  companyName String
  email       String
  phone       String
  country     String
  interest    String
  message     String   @db.Text
  source      String   @default("website")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}
